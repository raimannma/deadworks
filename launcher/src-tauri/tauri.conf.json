{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deadworks",
  "version": "0.2.9",
  "identifier": "net.deadworks.launcher",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Deadworks",
        "width": 900,
        "height": 560,
        "minWidth": 750,
        "minHeight": 450,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data:",
        "font-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost https://api.deadworks.net"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJERkFDRDYzQUEzNTJBQjUKUldTMUtqV3FZODM2TFJrbzhyTUNtT0ZaS0xVSmxGQ3hEdmttd0s0TlBmY1hsbmNUaVg1c0dpUjIK",
      "endpoints": [
        "https://api.deadworks.net/update/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
